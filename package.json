{
  "name": "pdf-translator",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "format": "pnpm oxfmt --write \"**/*.{js,mjs,ts,mts,d.ts,html}\"",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.8",
    "@angular/common": "^22.0.8",
    "@angular/compiler": "^22.0.8",
    "@angular/core": "^22.0.8",
    "@angular/forms": "^22.0.8",
    "@angular/platform-browser": "^22.0.8",
    "@angular/platform-browser-dynamic": "^22.0.8",
    "@angular/pwa": "^22.0.7",
    "@angular/router": "^22.0.8",
    "@angular/service-worker": "^22.0.8",
    "ngx-extended-pdf-viewer": "28.1.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.8",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/vite": "4",
    "@types/jasmine": "~6.0.0",
    "@types/node": "^26.1.1",
    "oxfmt": "^0.60.0",
    "postcss": "^8.5.22",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.3"
  }
}
